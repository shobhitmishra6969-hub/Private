modules = ["nodejs-20", "nix"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node run.js"

[userenv]

[userenv.shared]
LAVALINK_NODE_NAME = "Node1"
LAVALINK_URL = "lavalink.jirayu.net"
LAVALINK_AUTH = "youshallnotpass"
LAVALINK_SECURE = "True"

[[ports]]
localPort = 3000
externalPort = 80
